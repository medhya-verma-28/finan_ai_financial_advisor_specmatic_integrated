# Set the default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always use CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly declare text files you want to always use LF (Unix/Linux/macOS)
*.sh text eol=lf
*.js text eol=lf
*.json text eol=lf

# Denote all files that are truly binary and should not be modified
*.png diff=-text
*.jpg diff=-text

# Inside a file named .gitattributes in your project root
*.json text eol=lf
*.yaml text eol=lf
