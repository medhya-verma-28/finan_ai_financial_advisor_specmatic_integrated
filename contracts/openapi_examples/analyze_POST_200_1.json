{
    "http-request": {
        "path": "/analyze",
        "method": "POST",
        "headers": {
            "Content-Type": "application/json"
        },
        "body": {
            "query": "I have salary 100000 , cost of living 40 thousand, other investments 20 thousand, consumerist 5000, crisis shock expense 20 thousand. What is my category?"
        }
    },
    "http-response": {
        "status": 200,
        "headers": {
            "Content-Type": "application/json"
        },
        "body": {
            "query": "$match(dataType: string)",
            "extracted_features": {
                "monthly_income": "$match(dataType: integer)",
                "cost_of_living": "$match(dataType: integer)",
                "other_investments": "$match(dataType: integer)",
                "consumerist_expenditure": "$match(dataType: integer)",
                "crisis_shock_expenditure": "$match(dataType: integer)",
                "total_monthly_expenditure": "$match(dataType: integer)",
                "debt_status": "$match(dataType: string)"
            },
            "predictions": {
                "financial_state_category": "$match(dataType: string)",
                "current_monthly_income_enough": "$match(dataType: string)",
                "current_expenditure_worth_it": "$match(dataType: string)"
            },
            "recommendations": {
                "suggested_cost_of_living": "$match(dataType: number)",
                "suggested_other_investments": "$match(dataType: number)",
                "suggested_consumerist_expenditure": "$match(dataType: number)",
                "suggested_crisis_shocks": "$match(dataType: number)"
            },
            "gemini_report": "$match(dataType: string)"
        }
    }
}